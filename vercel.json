{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/admin/(.*)", "dest": "/admin/index.php" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
